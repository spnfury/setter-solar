                    "parameters": [
                        {
                            "name": "xc-token",
                            "value": "vodwktZQ77mth3XeK290Fw8V9Axloe1LiOxsWn5d"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify([{ Id: $json.leadRowId, status: 'Fallido', fecha_planificada: null }]) }}",
                "options": {}
            },
            "id": "update-lead-failed",
            "name": "Update Lead (Failed)",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1800,
                750
            ],
            "onError": "continueRegularOutput"
        },
        {
            "parameters": {
                "amount": 15,
                "unit": "seconds"
            },
            "id": "wait-between-calls",
            "name": "Wait 15s",
            "type": "n8n-nodes-base.wait",
            "typeVersion": 1.1,
            "position": [
