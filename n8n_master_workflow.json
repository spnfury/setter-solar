        {
            "parameters": {
                "rule": {
                    "interval": [
                        {
                            "field": "minutes",
                            "minutesInterval": 1
                        }
                    ]
                }
            },
            "id": "auto-schedule-trigger",
            "name": "Every 1 Min",
            "type": "n8n-nodes-base.scheduleTrigger",
            "position": [
                400,
                600
            ],
            "typeVersion": 1.1
        },
        {
            "parameters": {
                "method": "GET",
                "url": "https://optima-nocodb.vhsxer.easypanel.host/api/v2/tables/mf0wzufqcpi3bd1/records?limit=200&where=(status,eq,Programado)",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "xc-token",
                            "value": "vodwktZQ77mth3XeK290Fw8V9Axloe1LiOxsWn5d"
                        }
                    ]
                },
                "options": {}
            },
            "id": "get-leads-node",
            "name": "Get Programado Leads",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                600,
                600
            ],
            "onError": "continueRegularOutput"
        },
        {
            "parameters": {
                "jsCode": "// Extract leads from NocoDB response and filter only those that are due now\nconst input = $input.first().json;\nconst leads = input.list || [];\nconst now = new Date();\n\nconst dueLeads = leads.filter(lead => {\n  if (!lead.fecha_planificada) return false;\n  const plannedDate = new Date(lead.fecha_planificada);\n  return !isNaN(plannedDate.getTime()) && plannedDate <= now;\n});\n\nif (dueLeads.length === 0) {\n  return []; // No leads due — stop execution\n}\n\n// Return each due lead as a separate item for batch processing\nreturn dueLeads.map(lead => {\n  // Normalize phone number\n  let phone = String(lead.phone || '').replace(/\\D/g, '');\n  if (phone && !phone.startsWith('34')) phone = '34' + phone;\n  if (phone) phone = '+' + phone;\n\n  return {\n    json: {\n      leadId: lead.unique_id,\n      leadRowId: lead.Id,\n      name: lead.name || 'Cliente',\n      phone: phone,\n      address: lead.address || lead.Localidad || 'su localidad',\n      email: lead.email || '',\n      assistant_id: lead.assistant_id || '',\n      fecha_planificada: lead.fecha_planificada\n    }\n  };\n});"
            },
            "id": "filter-due-leads",
            "name": "Filter Due Leads",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                800,
                600
            ]
        },
        {
            "parameters": {
                "batchSize": 1,
                "options": {}
            },
            "id": "batch-calls",
            "name": "One at a Time",
            "type": "n8n-nodes-base.splitInBatches",
            "typeVersion": 3,
            "position": [
                1000,
                600
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "https://api.vapi.ai/call",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Authorization",
                            "value": "Bearer 0594f41c-e836-425d-aaa2-1c5b7d9e506e"
                        },
                        {
                            "name": "Content-Type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({ customer: { number: $json.phone }, assistantId: $json.assistant_id || 'f3359bb0-7bc4-45c7-9a02-ca4793cc5d48', phoneNumberId: 'e774df77-8fd0-4a17-a815-2acf8b6e3c2b', assistantOverrides: { variableValues: { nombre: $json.name, empresa: $json.name, ciudad: $json.address, tel_contacto: $json.phone, correo_cliente: $json.email, leadId: $json.leadId } } }) }}",
                "options": {}
            },
            "id": "launch-vapi-call",
            "name": "Launch Vapi Call",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1200,
                600
            ],
            "onError": "continueRegularOutput"
        },
        {
            "parameters": {
                "jsCode": "// Validate Vapi call response — only proceed if we got a real call ID\nconst vapiResponse = $input.first().json;\nconst callId = vapiResponse.id || '';\nconst leadData = $('One at a Time').item.json;\n\n// Check if Vapi actually created the call\nif (!callId || callId === 'unknown' || callId.length < 10) {\n  // Vapi call FAILED — mark lead as Fallido to prevent infinite retry\n  // and stop the pipeline from creating phantom log entries\n  return {\n    json: {\n      callSuccess: false,\n      vapiCallId: 'FAILED',\n      leadRowId: leadData.leadRowId,\n      leadId: leadData.leadId,\n      name: leadData.name,\n      phone: leadData.phone,\n      error: vapiResponse.message || vapiResponse.error || 'No call ID returned'\n    }\n  };\n}\n\n// Call succeeded\nreturn {\n  json: {\n    callSuccess: true,\n    vapiCallId: callId,\n    leadRowId: leadData.leadRowId,\n    leadId: leadData.leadId,\n    name: leadData.name,\n    phone: leadData.phone\n  }\n};"
            },
            "id": "check-call-success",
            "name": "Check Call Success",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1400,
                600
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "call-success-check",
                            "leftValue": "={{ $json.callSuccess }}",
                            "rightValue": true,
                            "operator": {
                                "type": "boolean",
                                "operation": "equals",
                                "name": "filter.operator.equals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "if-call-succeeded",
            "name": "Call Succeeded?",
