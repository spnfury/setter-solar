            "id": "vapi-webhook",
            "name": "Webhook Vapi",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1.1,
            "position": [
                400,
                300
            ]
        },
        {
            "parameters": {
                "jsCode": "const body = $input.first().json.body || $input.first().json;\n\n// Handle Vapi Tool Call OR Call Update (ended call with structured data)\nlet args = {};\nlet callId = '';\nlet toolCallId = '';\n\nif (body.message) {\n  const msg = body.message;\n  callId = msg.call?.id || '';\n  \n  if (msg.type === 'tool-calls') {\n    const toolCall = msg.toolCalls[0];\n    toolCallId = toolCall.id || '';\n    args = typeof toolCall.function.arguments === 'string' \n      ? JSON.parse(toolCall.function.arguments) \n      : toolCall.function.arguments;\n  } else if (msg.type === 'call-update' && msg.call?.status === 'ended') {\n    args = msg.call.analysis?.structuredData || {};\n  }\n}\n\nreturn {\n  datetime: args.datetime,\n  clientName: args.clientName,\n  clientPhone: args.clientPhone,\n  leadId: args.leadId || args.lead_id,\n  callId: callId || args.callId,\n  toolCallId: toolCallId\n};"
            },
            "id": "extract-data",
            "name": "Extract Data",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                600,
                300
            ]
        },
        {
            "parameters": {
                "calendar": {
                    "__rl": true,
                    "value": "primary",
                    "mode": "list"
                },
                "start": "={{ $json.datetime }}",
                "end": "={{ $json.datetime }}",
                "summary": "=Cita Solar: {{ $json.clientName }}",
                "description": "=Visita técnica concertada por la asistente virtual.\nCliente: {{ $json.clientName }}\nTeléfono: {{ $json.clientPhone }}\nLead ID: {{ $json.leadId }}",
                "additionalFields": {}
            },
            "id": "google-calendar",
            "name": "Google Calendar",
            "type": "n8n-nodes-base.googleCalendar",
            "typeVersion": 1.1,
            "position": [
                800,
                200
            ],
            "credentials": {
                "googleCalendarOAuth2Api": {
                    "id": "new-oauth2-id-placeholder",
                    "name": "Google Calendar OAuth2-V2"
                }
            },
            "onError": "continue"
        },
        {
            "parameters": {
                "authentication": "nocoDbApiToken",
                "operation": "create",
                "projectId": "p5xxqp29w9h8sb6",
