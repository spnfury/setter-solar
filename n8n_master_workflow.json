            "parameters": {
                "respondWith": "json",
                "responseBody": "={{ JSON.stringify({ results: [{ toolCallId: $('Extract Data').item.json.toolCallId, result: 'Cita agendada correctamente para ' + $json.datetime }] }) }}",
                "options": {}
