                "respondWith": "json",
                "responseBody": "={{ JSON.stringify({ results: [{ toolCallId: $('Extract Data').item.json.toolCallId, result: 'Cita cancelada correctamente.' }] }) }}",
                "options": {
                    "responseHeaders": {
